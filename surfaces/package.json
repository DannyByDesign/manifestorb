    "dependencies": {
        "@slack/bolt": "^3.12.2",
        "discord.js": "^14.25.1",
        "dotenv": "^16.3.1",
        "telegraf": "^4.16.3",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "typescript": "^5.3.3"
    }
}