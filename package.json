{
  "name": "amodel",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.2",
  "scripts": {
    "preinstall": "bun --version >/dev/null 2>&1",
    "postinstall": "prisma generate && bunx prisma generate --schema surfaces/prisma/schema.prisma",
    "dev": "next dev --webpack",
    "dev:stack": "bun run scripts/dev-stack.ts",
    "dev:turbo": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test-ai": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.ts tests/integration/**/*.integration.test.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:evals": "vitest run --config vitest.evals.config.ts",
    "eval:taxonomy": "bun run scripts/taxonomy-eval.ts --write-report",
    "eval:taxonomy:ci": "bun run scripts/taxonomy-eval.ts --ci --min-full=190 --write-report",
    "ci:taxonomy-gate": "bun run scripts/taxonomy-eval.ts --ci --min-full=190 --write-report && bun test-ai src/server/features/ai/tools/task-ownership.test.ts src/server/features/ai/tools/workflow.test.ts src/server/features/ai/tools/security.test.ts src/server/features/approvals/service.test.ts src/server/features/approvals/execute.test.ts tests/evals/taxonomy-eval.test.ts"
  },
