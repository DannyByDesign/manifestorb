// Approvals
// -----------------------------------------------------------------------------

model ApprovalPreference {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolName String // "modify", "delete", "send", "create", "workflow"
  policy   String // "always" | "never" | "conditional"
  conditions Json?

  @@unique([userId, toolName])
  @@index([userId])
}

model ApprovalRequest {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  provider       String   // e.g. "slack", "discord", "telegram", "web"
  status         String   // PENDING, APPROVED, DENIED, EXPIRED, CANCELED
  
  // JSON Blobs
  externalContext Json    // { workspaceId, channelId, messageTs, etc. }
  requestPayload  Json    // { actionType: "delete_event", args: { ... } }
  
  payloadHash    String   // SHA256 of requestPayload for auditing
  idempotencyKey String   @unique // Prevents duplicate requests
  correlationId  String?  // For tracing across systems
  
  decisions      ApprovalDecision[]

  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model ApprovalDecision {
  id                String          @id @default(cuid())
  approvalRequestId String
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  
  decidedByUserId   String
  decider           User            @relation(fields: [decidedByUserId], references: [id])
  
  decision          String          // "APPROVE" | "DENY"
  decisionPayload   Json?           // Optional extra data (e.g. "reason": "unsafe")
  
  decidedAt         DateTime        @default(now())

  @@index([approvalRequestId])
  @@index([decidedByUserId])
}

// -- RLM Context Models --

// Migrated to link with Conversation
model ConversationMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Identity
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Link to Stable Conversation
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Deduplication
  dedupeKey String @unique

  // Content
  role      String   // "user" | "assistant" | "system" | "tool"
  content   String   @db.Text
  toolCalls Json?    // Structured tool usage

  // Provenance
  provider          String  // "slack", "discord", "web"
  providerMessageId String? // External ID (Slack ts, Discord msgId)
  channelId         String? // External Channel ID
  threadId          String? // External Thread ID (if applicable)

  emailAccountId String? // Optional linkage

  @@index([userId, conversationId, createdAt])
}

model MemoryFact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  key       String   // e.g., "dietary_preference", "project_deadline"
  value     String   // e.g., "vegan", "Q3 2026"
  scope     String   // "global", "domain_specific"
  confidence Float   @default(1.0)

  // Provenance: Where did we learn this?
  sourceMessageId String?
  
  // Memory lifecycle management
  expiresAt       DateTime?        // Optional TTL for time-sensitive facts
  lastAccessedAt  DateTime?        // For LRU-based decay
  accessCount     Int      @default(0)  // Usage tracking for relevance
  isActive        Boolean  @default(true)  // Soft deletion

  @@unique([userId, key])
  @@index([userId, isActive])
  @@index([userId, lastAccessedAt])
  @@index([userId, confidence])
}

model PrivacySettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  recordHistory Boolean  @default(true)
  retentionDays Int      @default(90)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ConversationSummary {
  id             String       @id @default(cuid())
  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  summary        String    @db.Text
  updatedAt      DateTime  @updatedAt
  lastMessageAt  DateTime?
}

// User-level summary for unified cross-platform memory
// This replaces per-conversation summaries for context retrieval
model UserSummary {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  summary       String   @db.Text
  lastMessageAt DateTime
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model InAppNotification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content
  title     String
  body      String?
  type      String   // "info", "warning", "success", "error"
  metadata  Json?    // { source: "agent", actionUrl: "..." }

  // Atomic State Flags
  isRead          Boolean   @default(false) // User manually dismissed/read it
  readAt          DateTime? // When it was marked as read by user interaction
  
  claimedAt       DateTime? // Web client successfully fetched it (Delivery receipt)

  pushedToSurface Boolean   @default(false) // Fallback sent it to Slack
  pushedAt        DateTime?
  
  dedupeKey       String?   @unique // Encryption/Hash for idempotency
  
  @@index([userId, isRead])
  @@index([userId, createdAt])
}
