{
  "compilerOptions": {
    "target": "ES2017",
    "baseUrl": ".",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "zod/v3": ["./node_modules/zod"],
      "zod/v4": ["./node_modules/zod"],

      "@/server/*": ["./src/server/*"],
      "@/db/*": ["./src/server/db/*"],
      "@/integrations/*": ["./src/server/integrations/*"],
      "@/services/*": ["./src/server/services/*"],
      "@/utils/email/*": ["./src/server/services/email/*"],
      "@/utils/*": ["./src/server/utils/*"],
      "@/utils": ["./src/server/utils/index.ts"],
      "@/types/*": ["./src/server/types/*"],

      "@/components/*": ["./src/components/*"],
      "@/shaders/*": ["./src/shaders/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/hooks/*": ["./src/hooks/*"],

      "@/enterprise/*": ["./src/enterprise/*"],
      "@/__tests__/*": ["./src/__tests__/*"],
      "@amodel/*": ["./src/server/packages/*"],
      "@/generated/*": ["./generated/*"],

      "@/backend/*": ["./src/server/*"],
      "@/ee/*": ["./src/enterprise/*"],

      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules"
  ]
}
