{
  "compilerOptions": {
    "target": "ES2017",
    "baseUrl": ".",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@amodel/*": [
        "./src/server/packages/*"
      ],
      "@/generated/*": [
        "./generated/*"
      ],
      "@/utils/*": [
        "./src/server/utils/*"
      ],
      "@/utils": [
        "./src/server/utils/index.ts"
      ],
      "@/types/*": [
        "./src/server/types/*"
      ],
      "@/ee/*": [
        "./src/ee/*"
      ],
      "@/__tests__/*": [
        "./src/__tests__/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules"
  ]
}